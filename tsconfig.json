{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": ["vitest/globals", "node"],
    "paths": {
      "@app/*": ["./app/*"],
      "@components/*": ["./components/*"],
      "@calc": ["./lib/calculations/index.ts"],
      "@calc/*": ["./lib/calculations/*"]
    }
  },
  "include": ["app", "components", "lib", "tests", "scripts", "vite.config.ts"]
}
